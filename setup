#!/usr/bin/env bash
set -euo pipefail

TSTACK_ROOT="$(cd "$(dirname "$0")" && pwd)"
TARGET="$HOME/.claude/skills/tstack"

# Check if already installed
if [ -L "$TARGET" ]; then
  existing="$(readlink "$TARGET")"
  if [ "$existing" = "$TSTACK_ROOT" ]; then
    echo "tstack already installed at $TARGET"
    exit 0
  fi
  echo "Warning: $TARGET is a symlink pointing to $existing"
  printf "Overwrite? [y/N] "
  read -r answer
  if [ "$answer" != "y" ] && [ "$answer" != "Y" ]; then
    echo "Aborted."
    exit 1
  fi
  rm "$TARGET"
elif [ -d "$TARGET" ]; then
  echo "Warning: $TARGET is a real directory (not a symlink)."
  printf "Remove it and replace with symlink? [y/N] "
  read -r answer
  if [ "$answer" != "y" ] && [ "$answer" != "Y" ]; then
    echo "Aborted."
    exit 1
  fi
  rm -rf "$TARGET"
fi

# Create symlink
mkdir -p "$(dirname "$TARGET")"
ln -s "$TSTACK_ROOT" "$TARGET"

# Verify
if [ ! -f "$TARGET/.claude/skills/monetization-engineer/SKILL.md" ]; then
  echo "Error: symlink created but skill files not found. Check your tstack repo."
  exit 1
fi

echo "tstack installed at $TARGET"
echo ""
echo "Chain skills (design workflow):"
echo "  /monetization-engineer    Orchestrate the billing design chain"
echo "  /meter-design             Define billing units and measurement"
echo "  /pricing-model            Structure plans, tiers, and pricing"
echo "  /entitlement-enforcement  Design access control and limits"
echo "  /credit-ledger            Design prepaid credit pools"
echo "  /account-hierarchy        Multi-level accounts and key scoping"
echo "  /reconciliation           Usage-to-billing drift detection"
echo "  /provider-integration     Map design to Stripe"
echo ""
echo "Team skills (review & operations):"
echo "  /billing-reviewer         Audit billing code for race conditions and bugs"
echo "  /pricing-auditor          Evaluate unit economics and competitive position"
echo "  /billing-qa               Generate billing edge case test scenarios"
echo "  /alignment-check          Check pricing vs sales and business alignment"
echo "  /account-operations       Upgrade, downgrade, cancellation playbooks"
echo "  /credit-operations        Credit swaps, grants, and adjustments"
echo "  /migration-planner        Plan pricing model changes safely"
echo "  /revenue-reporter         MRR/ARR, rev rec, and month-end reporting"
echo "  /pql-scorer               Product-qualified lead scoring from usage"
echo "  /usage-intelligence       Account health and churn risk signals"
echo "  /api-health-analyst       Per-account error rates and reliability"
echo "  /billing-incident-investigator  Trace billing discrepancies to root cause"
echo "  /billing-monitor          Design billing alerts and drift detection"
echo "  /billing-ux-designer      Usage dashboards and billing UI patterns"
echo "  /pricing-researcher       Competitive pricing research and teardowns"
echo ""
echo "Run /monetization-engineer to design a billing system from scratch."
echo "Run any team skill to review or operate on an existing one."
